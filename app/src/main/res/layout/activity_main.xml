<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:backgroundTint="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/fundo"
    >
    <ImageView
        android:id="@+id/imgCapa"
        android:layout_width="match_parent"
        android:layout_height="330dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/nana3" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="43dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="@+id/LinhaGuiaEsquerda"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/netflixlogo" />

    <TextView
        android:id="@+id/txtSerie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Séries"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@+id/imgLogo"
        app:layout_constraintBottom_toBottomOf="@+id/imgLogo"
        app:layout_constraintEnd_toStartOf="@+id/txtFilmes"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/imgLogo" />

    <TextView
        android:id="@+id/txtFilmes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filmes"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/imgLogo"
        app:layout_constraintEnd_toStartOf="@+id/txtLista"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/txtSerie"
        app:layout_constraintTop_toTopOf="@+id/imgLogo" />

    <TextView
        android:id="@+id/txtLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minha Lista"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/imgLogo"
        app:layout_constraintBottom_toBottomOf="@+id/imgLogo"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/txtFilmes" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineHorizontalPrimeira"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.03"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineHorizontalSegunda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.10"/>

    <TextView
        android:id="@+id/txtAnime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Anime"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/txtRomance"
        app:layout_constraintEnd_toStartOf="@+id/txtRomance"
        app:layout_constraintStart_toStartOf="@+id/LinhaGuiaEsquerda"
        app:layout_constraintTop_toTopOf="@+id/txtRomance" />

    <TextView
        android:id="@+id/txtRomance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:padding="2dp"
        android:text="Romance"
        android:textColor="@color/white"
        app:layout_constraintEnd_toStartOf="@+id/txtEngracado"
        app:layout_constraintStart_toEndOf="@+id/txtAnime"
        app:layout_constraintTop_toBottomOf="@+id/imgNanaWord" />

    <TextView
        android:id="@+id/txtEngracado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Engraçado"
        android:padding="2dp"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/txtRomance"
        app:layout_constraintEnd_toEndOf="@+id/LinhaGuiaDireita"
        app:layout_constraintStart_toEndOf="@+id/txtRomance"
        app:layout_constraintTop_toTopOf="@+id/txtRomance" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineHorizontalTerceira"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.50" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/LinhaGuiaEsquerda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.04" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/LinhaGuiaDireita"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.96" />

    <Button
        android:id="@+id/btnAssistir"
        android:layout_width="130dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:drawableLeft="@drawable/icseta"
        android:text="Assistir"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/imgCapa"
        app:layout_constraintEnd_toStartOf="@+id/btnDetalhes"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/btnMinhaLista"
        app:layout_constraintTop_toBottomOf="@+id/txtRomance" />

    <Button
        android:id="@+id/btnMinhaLista"
        android:layout_width="116dp"
        android:layout_height="62dp"
        android:backgroundTint="@android:color/transparent"
        android:drawableTop="@drawable/icplus"
        android:padding="0dp"
        android:text="MINHA LISTA"
        android:textSize="10sp"
        app:layout_constraintTop_toTopOf="@+id/btnAssistir"
        app:layout_constraintBottom_toBottomOf="@id/btnAssistir"
        app:layout_constraintEnd_toStartOf="@+id/btnAssistir"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="271dp" />

    <Button
        android:id="@+id/btnDetalhes"
        android:layout_width="116dp"
        android:layout_height="62dp"
        android:backgroundTint="@android:color/transparent"
        android:drawableTop="@drawable/icinfo"
        android:padding="0dp"
        android:text="DETALHES"
        android:textSize="10sp"
        app:layout_constraintTop_toTopOf="@id/btnAssistir"
        app:layout_constraintBottom_toBottomOf="@id/btnAssistir"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/btnAssistir"
        tools:layout_editor_absoluteY="271dp" />

    <TextView
        android:id="@+id/txtLancamento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lançamentos"
        app:layout_constraintTop_toBottomOf="@id/btnAssistir"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="10dp"
        app:layout_constraintStart_toStartOf="@+id/LinhaGuiaEsquerda"
        android:textColor="@color/white"
        tools:layout_editor_absoluteX="36dp"
        tools:layout_editor_absoluteY="373dp" />

    <ImageView
        android:id="@+id/imgNanaWord"
        android:layout_width="145dp"
        android:layout_height="85dp"
        android:layout_marginTop="36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideLineHorizontalSegunda"
        app:srcCompat="@drawable/nana2" />

    <ImageView
        android:id="@+id/imgDexter"
        android:layout_width="110dp"
        app:layout_constraintEnd_toStartOf="@+id/imgSatc"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toStartOf="@id/LinhaGuiaEsquerda"
        app:layout_constraintTop_toBottomOf="@id/txtLancamento"
        android:layout_height="75dp"
        app:srcCompat="@drawable/dxt"
        tools:layout_editor_absoluteX="26dp"
        tools:layout_editor_absoluteY="422dp" />

    <ImageView
        android:id="@+id/imgSatc"
        android:layout_width="110dp"
        android:layout_height="75dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgDexter"
        app:layout_constraintEnd_toStartOf="@+id/imgTheOffice"
        app:layout_constraintStart_toEndOf="@+id/imgDexter"
        app:layout_constraintTop_toTopOf="@+id/imgDexter"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/stac" />

    <ImageView
        android:id="@+id/imgTheOffice"
        android:layout_width="110dp"
        android:layout_height="75dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgSatc"
        app:layout_constraintEnd_toEndOf="@id/LinhaGuiaDireita"
        app:layout_constraintStart_toEndOf="@+id/imgSatc"
        app:layout_constraintTop_toTopOf="@+id/imgSatc"
        app:srcCompat="@drawable/theoffice" />



</androidx.constraintlayout.widget.ConstraintLayout>